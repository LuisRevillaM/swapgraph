{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketListingView.schema.json",
  "title": "MarketListingView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "listing_id",
    "workspace_id",
    "owner_actor",
    "kind",
    "status",
    "title",
    "description",
    "offer",
    "want_spec",
    "budget",
    "constraints",
    "capability_profile",
    "expires_at",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "listing_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_actor": {
      "$ref": "ActorRef.schema.json"
    },
    "owner_profile": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "actor",
        "display_name",
        "handle",
        "owner_mode",
        "default_workspace_id",
        "bio",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "actor": {
          "$ref": "ActorRef.schema.json"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "handle": {
          "type": "string",
          "minLength": 1
        },
        "owner_mode": {
          "type": "string",
          "enum": [
            "agent_owner",
            "operator",
            "builder"
          ]
        },
        "default_workspace_id": {
          "type": "string",
          "minLength": 1
        },
        "bio": {
          "type": [
            "string",
            "null"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "kind": {
      "type": "string",
      "enum": [
        "post",
        "want",
        "capability"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "paused",
        "closed",
        "suspended"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "offer": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "want_spec": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "budget": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "constraints": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "capability_profile": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "deliverable_schema",
        "rate_card"
      ],
      "properties": {
        "deliverable_schema": {
          "type": "object",
          "additionalProperties": true
        },
        "rate_card": {
          "type": "object",
          "additionalProperties": true
        },
        "sla_hint": {
          "type": "object",
          "additionalProperties": true
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
