{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketBlueprintPatchRequest.schema.json",
  "title": "MarketBlueprintPatchRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["patch"],
  "properties": {
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": ["string", "null"] },
        "category": { "type": "string", "enum": ["skill", "workflow", "prompt_pack", "agent_template", "sdk_module", "integration_recipe", "evaluation_harness"] },
        "artifact_ref": { "type": "string", "minLength": 1 },
        "artifact_format": { "type": "string", "minLength": 1 },
        "license_terms": { "type": ["string", "null"] },
        "support_policy": { "type": ["object", "null"], "additionalProperties": true },
        "verification_spec": { "type": ["object", "null"], "additionalProperties": true },
        "delivery_mode": { "type": "string", "enum": ["download", "repo_access", "bundle_export", "template_clone", "hosted_copy"] },
        "pricing_model": { "type": "string", "enum": ["one_time", "seat", "usage", "support_bundle", "barter_only"] },
        "valuation_hint": { "type": ["object", "null"], "additionalProperties": true }
      }
    },
    "recorded_at": { "type": "string", "format": "date-time" }
  }
}
