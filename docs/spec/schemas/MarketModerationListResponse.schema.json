{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketModerationListResponse.schema.json",
  "title": "MarketModerationListResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "moderation_items",
    "total",
    "actor_scope"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "moderation_items": {
      "type": "array",
      "items": {
        "$ref": "MarketModerationView.schema.json"
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "actor_scope": {
      "type": "string",
      "enum": ["owner", "moderator"]
    }
  }
}
