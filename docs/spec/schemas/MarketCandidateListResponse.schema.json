{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketCandidateListResponse.schema.json",
  "title": "MarketCandidateListResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["correlation_id", "candidates", "total", "next_cursor"],
  "properties": {
    "correlation_id": { "type": "string", "minLength": 1 },
    "candidates": { "type": "array", "items": { "$ref": "MarketCandidateView.schema.json" } },
    "total": { "type": "integer", "minimum": 0 },
    "next_cursor": { "type": ["string", "null"], "minLength": 1 }
  }
}
