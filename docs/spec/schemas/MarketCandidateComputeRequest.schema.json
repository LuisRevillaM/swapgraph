{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketCandidateComputeRequest.schema.json",
  "title": "MarketCandidateComputeRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspace_id"],
  "properties": {
    "workspace_id": { "type": "string", "minLength": 1 },
    "max_cycle_length": { "type": "integer", "minimum": 2, "maximum": 6 },
    "max_candidates": { "type": "integer", "minimum": 1, "maximum": 100 },
    "recorded_at": { "type": "string", "format": "date-time" }
  }
}
