{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketDealListResponse.schema.json",
  "title": "MarketDealListResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "deals",
    "total",
    "next_cursor"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "deals": {
      "type": "array",
      "items": {
        "$ref": "MarketDealView.schema.json"
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "next_cursor": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
