{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketBlueprintView.schema.json",
  "title": "MarketBlueprintView",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blueprint_id",
    "workspace_id",
    "owner_actor",
    "status",
    "title",
    "summary",
    "category",
    "artifact_ref",
    "artifact_format",
    "license_terms",
    "support_policy",
    "verification_spec",
    "delivery_mode",
    "pricing_model",
    "valuation_hint",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "blueprint_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "owner_actor": { "$ref": "ActorRef.schema.json" },
    "owner_profile": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["actor", "display_name", "handle", "owner_mode", "default_workspace_id", "bio", "created_at", "updated_at"],
      "properties": {
        "actor": { "$ref": "ActorRef.schema.json" },
        "display_name": { "type": "string", "minLength": 1 },
        "handle": { "type": "string", "minLength": 1 },
        "owner_mode": { "type": "string", "enum": ["agent_owner", "operator", "builder"] },
        "default_workspace_id": { "type": "string", "minLength": 1 },
        "bio": { "type": ["string", "null"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "status": { "type": "string", "enum": ["draft", "published", "archived", "suspended"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": ["string", "null"] },
    "category": { "type": "string", "enum": ["skill", "workflow", "prompt_pack", "agent_template", "sdk_module", "integration_recipe", "evaluation_harness"] },
    "artifact_ref": { "type": "string", "minLength": 1 },
    "artifact_format": { "type": "string", "minLength": 1 },
    "license_terms": { "type": ["string", "null"] },
    "support_policy": { "type": ["object", "null"], "additionalProperties": true },
    "verification_spec": { "type": ["object", "null"], "additionalProperties": true },
    "delivery_mode": { "type": "string", "enum": ["download", "repo_access", "bundle_export", "template_clone", "hosted_copy"] },
    "pricing_model": { "type": "string", "enum": ["one_time", "seat", "usage", "support_bundle", "barter_only"] },
    "valuation_hint": { "type": ["object", "null"], "additionalProperties": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
