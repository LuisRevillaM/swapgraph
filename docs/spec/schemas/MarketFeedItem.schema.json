{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketFeedItem.schema.json",
  "title": "MarketFeedItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "item_type",
    "item_id",
    "workspace_id",
    "occurred_at"
  ],
  "properties": {
    "item_type": {
      "type": "string",
      "enum": [
        "listing",
        "edge",
        "deal"
      ]
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "listing_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "listing_id",
        "kind",
        "status",
        "title",
        "owner_actor",
        "updated_at"
      ],
      "properties": {
        "listing_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "post",
            "want",
            "capability"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "paused",
            "closed",
            "suspended"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "owner_actor": {
          "$ref": "ActorRef.schema.json"
        },
        "owner_profile": {
          "$ref": "MarketActorProfileView.schema.json"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "edge_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "edge_type",
        "status",
        "source_ref",
        "target_ref",
        "updated_at"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "edge_type": {
          "type": "string",
          "enum": [
            "interest",
            "offer",
            "counter",
            "block"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "accepted",
            "declined",
            "withdrawn",
            "expired"
          ]
        },
        "source_ref": {
          "$ref": "MarketEdgeRef.schema.json"
        },
        "target_ref": {
          "$ref": "MarketEdgeRef.schema.json"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "deal_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deal_id",
        "origin_edge_id",
        "settlement_mode",
        "status",
        "updated_at"
      ],
      "properties": {
        "deal_id": {
          "type": "string",
          "minLength": 1
        },
        "origin_edge_id": {
          "type": "string",
          "minLength": 1
        },
        "settlement_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "internal_credit",
            "external_payment_proof",
            "cycle_bridge",
            null
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "pending_accept",
            "ready_for_settlement",
            "settlement_in_progress",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "participants": {
          "type": "array",
          "items": {
            "$ref": "ActorRef.schema.json"
          }
        },
        "receipt_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
