{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketExecutionGrantCreateRequest.schema.json",
  "title": "MarketExecutionGrantCreateRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["grant"],
  "properties": {
    "grant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audience", "scope", "grant_mode"],
      "properties": {
        "grant_id": {
          "type": "string",
          "minLength": 1
        },
        "deal_id": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "$ref": "ActorRef.schema.json"
        },
        "scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "grant_mode": {
          "type": "string",
          "enum": ["token", "encrypted_envelope"]
        },
        "ciphertext": {
          "type": "string",
          "minLength": 1
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "nonce": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
