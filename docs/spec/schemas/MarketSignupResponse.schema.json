{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketSignupResponse.schema.json",
  "title": "MarketSignupResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "actor",
    "owner_profile",
    "auth_hints"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "$ref": "ActorRef.schema.json"
    },
    "owner_profile": {
      "$ref": "MarketActorProfileView.schema.json"
    },
    "auth_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scopes"
      ],
      "properties": {
        "scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
