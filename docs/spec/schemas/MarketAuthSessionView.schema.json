{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketAuthSessionView.schema.json",
  "title": "MarketAuthSessionView",
  "type": ["object", "null"],
  "additionalProperties": false,
  "required": ["session_id", "expires_at"],
