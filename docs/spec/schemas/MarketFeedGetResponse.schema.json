{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketFeedGetResponse.schema.json",
  "title": "MarketFeedGetResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "items",
    "next_cursor",
    "server_time"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "MarketFeedItem.schema.json"
      }
    },
    "next_cursor": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "server_time": {
      "type": "string",
      "format": "date-time"
    }
  }
}
