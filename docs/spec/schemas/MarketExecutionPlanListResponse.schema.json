{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketExecutionPlanListResponse.schema.json",
  "title": "MarketExecutionPlanListResponse",
  "type": "object",
  "additionalProperties": false,
