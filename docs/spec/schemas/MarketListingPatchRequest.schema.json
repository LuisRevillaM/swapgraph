{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swapgraph.dev/schemas/MarketListingPatchRequest.schema.json",
  "title": "MarketListingPatchRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "patch"
  ],
  "properties": {
    "patch": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "offer": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "want_spec": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "budget": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "constraints": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "capability_profile": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": false,
          "required": [
            "deliverable_schema",
            "rate_card"
          ],
          "properties": {
            "deliverable_schema": {
              "type": "object",
              "additionalProperties": true
            },
            "rate_card": {
              "type": "object",
              "additionalProperties": true
            },
            "sla_hint": {
              "type": "object",
              "additionalProperties": true
            },
            "constraints": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
